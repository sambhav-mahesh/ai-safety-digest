<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Safety Weekly Digest — {{ week_start }} to {{ week_end }}</title>
  <meta name="description" content="A curated weekly digest of {{ total_count }} AI safety research papers from leading organizations and researchers. {{ week_start }} through {{ week_end }}.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400..800;1,6..72,400..600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    {{ css | safe }}
  </style>
</head>
<body>

  {# ── Reusable date-formatting macro ── #}
  {%- macro fmt_date(date_val) -%}
    {%- set months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'] -%}
    {%- set dstr = date_val|string -%}
    {%- if date_val and 'T' in dstr -%}
      {%- set pd_date = dstr.split('T')[0] -%}
      {%- set pd_year = pd_date.split('-')[0] -%}
      {%- set pd_month = pd_date.split('-')[1]|int -%}
      {%- set pd_day = pd_date.split('-')[2]|int -%}
      {{ months[pd_month - 1] }} {{ pd_day }}, {{ pd_year }}
    {%- elif date_val and '-' in dstr -%}
      {%- set pd_year = dstr.split('-')[0] -%}
      {%- set pd_month = dstr.split('-')[1]|int -%}
      {%- set pd_day = dstr.split('-')[2]|int -%}
      {{ months[pd_month - 1] }} {{ pd_day }}, {{ pd_year }}
    {%- else -%}
      {{ date_val }}
    {%- endif -%}
  {%- endmacro -%}

  {# ── Reusable paper card macro ── #}
  {%- macro paper_card(paper, card_class="grid-card") -%}
  <article class="paper-card {{ card_class }}" data-org="{{ paper.organization }}">
    <div class="paper-meta">
      <span class="org-tag" data-org="{{ paper.organization }}"><span class="org-dot" aria-hidden="true"></span>{{ paper.organization }}</span>
      <span class="paper-date">{{ fmt_date(paper.published_date) }}</span>
    </div>
    <h3 class="paper-title">
      <a href="{{ paper.url }}" target="_blank" rel="noopener noreferrer">{{ paper.title }}</a>
    </h3>
    {%- if paper.authors %}
    <p class="paper-authors">{{ paper.authors | join(', ') if paper.authors is iterable and paper.authors is not string else paper.authors }}</p>
    {%- endif %}
    {%- if paper.abstract %}
    <div class="paper-abstract">
      <details class="abstract-expand">
        <summary class="abstract-toggle">
          <span class="abstract-preview">{{ paper.abstract }}</span>
          <span class="toggle-label">More</span>
        </summary>
        <div class="abstract-full">{{ paper.abstract }}</div>
      </details>
    </div>
    {%- endif %}
    <a href="{{ paper.url }}" class="read-link" target="_blank" rel="noopener noreferrer">Read paper &rarr;</a>
  </article>
  {%- endmacro -%}

  <!-- Masthead -->
  <header class="site-header">
    <div class="header-inner">
      <p class="header-eyebrow">Weekly research digest</p>
      <h1 class="site-title">AI Safety <em>Digest</em></h1>
      <p class="header-tagline">Papers, technical posts, and reports on alignment, interpretability, evaluations, and AI governance &mdash; collected from {{ organizations | length }} organizations every Monday.</p>
      <div class="header-meta">
        <span class="header-daterange">{{ week_start }} &mdash; {{ week_end }}</span>
        {%- if total_count %}
        <span class="header-separator" aria-hidden="true"></span>
        <span class="header-count"><strong>{{ total_count }}</strong> papers this week</span>
        {%- endif %}
      </div>
    </div>
  </header>

  <!-- Filter Bar -->
  <nav class="filter-bar" aria-label="Filter papers">
    <div class="filter-bar-inner">
      <div class="search-wrap">
        <svg class="search-icon" aria-hidden="true" viewBox="0 0 16 16" width="14" height="14"><circle cx="7" cy="7" r="5" fill="none" stroke="currentColor" stroke-width="1.6"/><line x1="10.8" y1="10.8" x2="14.2" y2="14.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        <input type="search" id="paper-search" class="search-input" placeholder="Search titles &amp; abstracts&hellip;" aria-label="Search papers">
      </div>
      <div class="filter-scroll">
        <button class="filter-pill active" data-filter="all">All{% if total_count %} <span class="pill-count">{{ total_count }}</span>{% endif %}</button>
        {%- for org in organizations %}
        <button class="filter-pill" data-filter="{{ org }}" data-org="{{ org }}"><span class="org-dot" aria-hidden="true"></span>{{ org }}{% if org_counts and org_counts.get(org) %} <span class="pill-count">{{ org_counts[org] }}</span>{% endif %}</button>
        {%- endfor %}
      </div>
    </div>
  </nav>

  <!-- Featured Section -->
  {% if featured_papers %}
  <section class="hero-section">
    <h2 class="section-label">Featured this week</h2>
    <div class="hero-grid">
      {%- for paper in featured_papers %}
      {{ paper_card(paper, "hero-card") }}
      {%- endfor %}
    </div>
  </section>
  {% endif %}

  <!-- Papers Grid -->
  <main class="papers-section">
    {% if papers %}
    <h2 class="section-label">All papers</h2>
    <div class="papers-grid">
      {%- for paper in papers %}
      {{ paper_card(paper, "grid-card") }}
      {%- endfor %}
    </div>
    {% elif not featured_papers %}
    <div class="empty-state">
      <p>No papers found for this week.</p>
      <p class="empty-sub">Check back soon &mdash; new research is published daily.</p>
    </div>
    {% endif %}
    <div class="no-results" id="no-results" hidden>
      <p>Nothing matches your search.</p>
      <p class="empty-sub">Try a different term, or clear the organization filter.</p>
    </div>
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-note">Curated automatically from {{ organizations | length }} sources &middot; <a href="https://github.com/sambhav-mahesh/ai-safety-digest" target="_blank" rel="noopener noreferrer">Source on GitHub</a></p>
      <p class="footer-timestamp">Last updated {{ last_updated }}</p>
    </div>
  </footer>

  <!-- Filter + Search JS -->
  <script>
    (function () {
      var pills = document.querySelectorAll('.filter-pill');
      var cards = document.querySelectorAll('.paper-card');
      var heroSection = document.querySelector('.hero-section');
      var gridLabel = document.querySelector('.papers-section .section-label');
      var papersGrid = document.querySelector('.papers-grid');
      var noResults = document.getElementById('no-results');
      var searchInput = document.getElementById('paper-search');

      var activeOrg = 'all';
      var query = '';

      // Pre-index card text once for fast search
      cards.forEach(function (card) {
        card.setAttribute('data-text', card.textContent.toLowerCase());
      });

      function applyFilters() {
        var heroVisible = 0;
        var gridVisible = 0;
        cards.forEach(function (card) {
          var orgOk = activeOrg === 'all' || card.getAttribute('data-org') === activeOrg;
          var textOk = !query || card.getAttribute('data-text').indexOf(query) !== -1;
          var show = orgOk && textOk;
          card.style.display = show ? '' : 'none';
          if (show && card.classList.contains('hero-card')) heroVisible++;
          if (show && card.classList.contains('grid-card')) gridVisible++;
        });
        if (heroSection) heroSection.style.display = heroVisible > 0 ? '' : 'none';
        if (gridLabel) gridLabel.style.display = gridVisible > 0 ? '' : 'none';
        if (papersGrid) papersGrid.style.display = gridVisible > 0 ? '' : 'none';
        if (noResults) noResults.hidden = (heroVisible + gridVisible) > 0;
      }

      pills.forEach(function (pill) {
        pill.addEventListener('click', function () {
          activeOrg = this.getAttribute('data-filter');
          pills.forEach(function (p) { p.classList.remove('active'); });
          this.classList.add('active');
          applyFilters();
        });
      });

      if (searchInput) {
        searchInput.addEventListener('input', function () {
          query = this.value.trim().toLowerCase();
          applyFilters();
        });
      }
    })();
  </script>

</body>
</html>
